<UserControl x:Class="WpfApp1.VisionInspectionPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1200"
             Background="#1E1E2E"
             Loaded="UserControl_Loaded"
             Unloaded="UserControl_Unloaded">
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>
        
        <!-- 标题 -->
        <TextBlock Grid.Row="0" Text="质检与监控 - 海康相机视觉检测" 
                   FontSize="24" FontWeight="Bold" Foreground="White" 
                   Margin="0,0,0,15"/>
        
        <!-- 相机预览和参数区域 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- 相机预览区域 -->
            <Border Grid.Column="0" Background="#2D2D3D" CornerRadius="10" Margin="0,0,10,0">
                <Grid>
                    <!-- 预览占位文字 -->
                    <TextBlock x:Name="PreviewPlaceholder"
                               Text="相机未连接，请点击连接相机按钮"
                               FontSize="18" Foreground="#888888"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               TextAlignment="Center"/>
                    
                    <!-- 图像显示 -->
                    <Image x:Name="CameraImage" Stretch="Uniform" Visibility="Collapsed"/>
                </Grid>
            </Border>
            
            <!-- 参数控制区域 -->
            <Border Grid.Column="1" Background="#2D2D3D" CornerRadius="10" Padding="15">
                <StackPanel>
                    <TextBlock Text="相机连接" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>
                    
                    <!-- 连接状态 -->
                    <TextBlock x:Name="ConnectionStatusText" Text="状态: 未连接" Foreground="#FF6B6B" Margin="0,0,0,10"/>
                    
                    <!-- 连接状态 -->
                    <TextBlock x:Name="CameraInfoText" Text="相机信息: --" Foreground="#CCCCCC" TextWrapping="Wrap" Margin="0,0,0,10"/>
                    
                    <!-- IP显示 -->
                    <TextBlock x:Name="IpText" Text="IP: --" Foreground="#CCCCCC" Margin="0,0,0,15"/>
                    
                    <!-- 曝光时间 -->
                    <TextBlock Text="曝光时间 (ms):" Foreground="White" Margin="0,0,0,5"/>
                    <Slider x:Name="ExposureSlider" Minimum="1" Maximum="100" Value="20"/>
                    <TextBlock x:Name="ExposureValueText" Text="20 ms" Foreground="#CCCCCC" Margin="0,0,0,15"/>
                    
                    <!-- 增益 -->
                    <TextBlock Text="增益 (dB):" Foreground="White" Margin="0,0,0,5"/>
                    <Slider x:Name="GainSlider" Minimum="0" Maximum="20" Value="10"/>
                    <TextBlock x:Name="GainValueText" Text="10 dB" Foreground="#CCCCCC" Margin="0,0,0,15"/>
                    
                    <!-- 帧数统计 -->
                    <TextBlock x:Name="FrameCountText" Text="帧数: 0" Foreground="#4ECDC4" FontSize="16" Margin="0,0,0,5"/>
                    <TextBlock x:Name="FpsText" Text="帧率: 0 FPS" Foreground="#4ECDC4" FontSize="16" Margin="0,0,0,15"/>
                    
                    <!-- 操作按钮 -->
                    <Button x:Name="BtnConnect" Content="连接相机" Click="BtnConnect_Click" 
                            Height="40" Margin="0,5" Background="#4ECDC4" Foreground="White" FontWeight="Bold"/>
                    <Button x:Name="BtnStartGrab" Content="开始采集" Click="BtnStartGrab_Click" 
                            Height="40" Margin="0,5" IsEnabled="False" Background="#FF6B6B" Foreground="White" FontWeight="Bold"/>
                    <Button x:Name="BtnStopGrab" Content="停止采集" Click="BtnStopGrab_Click" 
                            Height="40" Margin="0,5" IsEnabled="False" Background="#FFE66D" Foreground="#1E1E2E" FontWeight="Bold"/>
                    <Button x:Name="BtnDisconnect" Content="断开连接" Click="BtnDisconnect_Click" 
                            Height="40" Margin="0,5" IsEnabled="False" Background="#95A5A6" Foreground="White" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </Grid>
        
        <!-- 分隔线 -->
        <Separator Grid.Row="2" Background="#3D3D4D" Margin="0,10"/>
        
        <!-- 操作日志 -->
        <Border Grid.Row="3" Background="#2D2D3D" CornerRadius="10" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Grid.Row="0">
                    <TextBlock Text="操作日志" FontSize="14" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    <Button Content="清空日志" Click="BtnClearLog_Click" Margin="20,0,0,0" Padding="10,2"/>
                </StackPanel>
                <ScrollViewer x:Name="LogScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,5,0,0">
                    <TextBlock x:Name="LogText" Text="" Foreground="#CCCCCC" TextWrapping="Wrap" FontFamily="Consolas"/>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
