<UserControl x:Class="WpfApp1.VisionInspectionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:wf="clr-namespace:System.Windows.Forms;assembly=System.Windows.Forms"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="800"
      Title="VisionInspectionPage"
      Loaded="VisionInspectionPage_Loaded"
      Unloaded="VisionInspectionPage_Unloaded">
    <!-- 诊断：页面是否加载可见 -->
    <Border x:Name="DiagBorder" Background="Yellow" Padding="10" 
            HorizontalAlignment="Center" VerticalAlignment="Center" 
            Visibility="Visible" Panel.ZIndex="9999">
        <TextBlock Text="⚠️ 诊断：VisionInspectionPage已加载！如果是黄底黑字说明页面正常渲染。" 
                   FontSize="18" FontWeight="Bold" Foreground="Black"/>
    </Border>

    <Grid x:Name="MainGrid" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Visibility="Visible">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 相机图像显示区域 - 使用WinForms PictureBox通过WindowsFormsHost -->
        <Border Grid.Row="0" Background="Black" Margin="5">
            <WindowsFormsHost x:Name="CameraDisplayHost">
                <wf:PictureBox x:Name="CameraPictureBox" Dock="Fill" 
                               SizeMode="StretchImage" BackColor="Black"/>
            </WindowsFormsHost>
        </Border>

        <!-- 底部控制栏 -->
        <Border Grid.Row="1" Background="#F0F0F0" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Grid.Column="0" Margin="0,0,10,0">
                    <Button x:Name="StartCameraButton" Content="开始采集" Width="80" Height="30"
                            Click="StartCameraButton_Click" Margin="0,0,5,0"/>
                    <Button x:Name="StopCameraButton" Content="停止采集" Width="80" Height="30"
                            Click="StopCameraButton_Click" Margin="0,0,5,0"/>
                    <Button x:Name="SaveImageButton" Content="保存图像" Width="80" Height="30"
                            Click="SaveImageButton_Click" Margin="0,0,5,0"/>
                    <Button x:Name="ClearLogButton" Content="清除日志" Width="80" Height="30"
                            Click="ClearLogButton_Click"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Grid.Column="5">
                    <TextBlock x:Name="StatusText" Text="未连接" VerticalAlignment="Center"
                               Foreground="Gray" Margin="0,0,10,0"/>
                    <TextBlock x:Name="FrameCountText" Text="帧数: 0" VerticalAlignment="Center"
                               Foreground="Gray"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 日志区域 -->
        <Border Grid.Row="0" VerticalAlignment="Bottom" HorizontalAlignment="Right"
                Background="#80000000" Margin="5" Padding="5" MaxHeight="150" MaxWidth="400">
            <TextBox x:Name="LogTextBox" IsReadOnly="True" Background="Transparent"
                     Foreground="LightGreen" BorderThickness="0" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="11"/>
        </Border>
    </Grid>
</UserControl>
