<Page x:Class="WpfApp1.VisionInspectionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="700" d:DesignWidth="1000"
      Background="#1a1a2e">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="150"/>
        </Grid.RowDefinitions>

        <!-- 页面标题 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="质检与监控 - 海康相机视觉检测" 
                       Foreground="White" FontSize="24" FontWeight="Bold"/>
        </StackPanel>

        <!-- 相机连接状态栏 -->
        <Border Grid.Row="1" Background="#16213e" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusIndicator" Width="12" Height="12" Fill="#666" Margin="0,0,10,0"/>
                    <TextBlock x:Name="CameraStatusText" Text="相机未连接" 
                               Foreground="White" FontSize="14" VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Grid.Column="1" x:Name="SerialNoText" Text="序列号: --" 
                           Foreground="#888" FontSize="13" VerticalAlignment="Center" 
                           HorizontalAlignment="Center"/>

                <TextBlock Grid.Column="2" x:Name="CurrentTimeText" 
                           Foreground="#888" FontSize="13" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- 相机预览区域 -->
        <Border Grid.Row="2" Background="#0f0f23" CornerRadius="8" BorderBrush="#333" BorderThickness="1">
            <Grid>
                <Image x:Name="CameraImage" Stretch="Uniform"/>
                <TextBlock x:Name="PreviewPlaceholder" Text="点击「连接相机」开始预览" 
                           Foreground="#555" FontSize="18" 
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- 控制按钮区域 -->
        <Border Grid.Row="3" Background="#16213e" CornerRadius="8" Padding="20" Margin="0,15,0,15">
            <WrapPanel HorizontalAlignment="Center">
                <Button x:Name="BtnConnect" Content="连接相机" Width="120" Height="40" 
                        Margin="10" Click="BtnConnect_Click"
                        Background="#4CAF50" Foreground="White" FontSize="14"
                        BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}" 
                                    CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="BtnStartGrab" Content="开始采集" Width="120" Height="40" 
                        Margin="10" Click="BtnStartGrab_Click" IsEnabled="False"
                        Background="#2196F3" Foreground="White" FontSize="14"
                        BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}" 
                                    CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="BtnStopGrab" Content="停止采集" Width="120" Height="40" 
                        Margin="10" Click="BtnStopGrab_Click" IsEnabled="False"
                        Background="#FF9800" Foreground="White" FontSize="14"
                        BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}" 
                                    CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="BtnDisconnect" Content="断开连接" Width="120" Height="40" 
                        Margin="10" Click="BtnDisconnect_Click" IsEnabled="False"
                        Background="#f44336" Foreground="White" FontSize="14"
                        BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}" 
                                    CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </WrapPanel>
        </Border>

        <!-- 操作日志 -->
        <Border Grid.Row="4" Background="#16213e" CornerRadius="8" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="操作日志" Foreground="White" FontSize="14" FontWeight="Bold"/>
                    <Button Content="清空日志" Margin="20,0,0,0" Padding="10,2" 
                            Click="BtnClearLog_Click"
                            Background="#333" Foreground="White" FontSize="12"
                            BorderThickness="0" Cursor="Hand"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="LogText" Foreground="#aaa" FontSize="12" 
                               TextWrapping="Wrap" FontFamily="Consolas"/>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Page>
