<UserControl x:Class="WpfApp1.VisionInspectionPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F7FA">

    <UserControl.Resources>
        <!-- 卡片样式 -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0 0 15 15"/>
        </Style>

        <!-- 状态指示灯 -->
        <Style x:Key="StatusLight" TargetType="Ellipse">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="Margin" Value="0 0 8 0"/>
        </Style>

        <!-- 操作按钮样式 -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#635BFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20 12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btnBorder" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="btnBorder" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="btnBorder" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="btnBorder" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 文本框样式 -->
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="0 0 0 10"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 页面标题 -->
        <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="0 0 0 15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="质检与监控 - 海康相机视觉检测" FontSize="20" FontWeight="Bold" Foreground="#12142D" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Ellipse Style="{StaticResource StatusLight}" Fill="#10B981" VerticalAlignment="Center"/>
                    <TextBlock x:Name="CameraStatusText" Text="相机未连接" Foreground="#666" FontSize="14" VerticalAlignment="Center" Margin="0 0 20 0"/>
                    <TextBlock x:Name="CurrentTimeText" Text="" Foreground="#666" FontSize="14" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 主要内容区 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧相机预览区 -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- 相机预览卡片 -->
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="相机预览" FontSize="16" FontWeight="Bold" Foreground="#12142D" Margin="0 0 0 15"/>
                            <Border Background="#1E2142" CornerRadius="8" Height="450">
                                <Grid>
                                    <TextBlock x:Name="PreviewPlaceholder" Text="点击"开始采集"显示图像" Foreground="#666" FontSize="18" 
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Image x:Name="CameraImage" Stretch="None"/>
                                    <Canvas>
                                        <Border x:Name="RoiBorder" BorderBrush="#10B981" BorderThickness="2" 
                                                Width="300" Height="300" Canvas.Left="250" Canvas.Top="75" Opacity="0.7"/>
                                        <Line x:Name="CrosshairH" X1="0" Y1="225" X2="800" Y2="225" Stroke="#10B981" StrokeThickness="1" Opacity="0.7"/>
                                        <Line x:Name="CrosshairV" X1="400" Y1="0" X2="400" Y2="450" Stroke="#10B981" StrokeThickness="1" Opacity="0.7"/>
                                    </Canvas>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- 检测结果卡片 -->
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="检测结果" FontSize="16" FontWeight="Bold" Foreground="#12142D" Margin="0 0 0 15"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Background="#F0F4FF" CornerRadius="8" Padding="15" Margin="0 0 10 0">
                                    <StackPanel>
                                        <TextBlock Text="检测数量" Foreground="#666" FontSize="12"/>
                                        <TextBlock Text="0" Foreground="#12142D" FontSize="24" FontWeight="Bold"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#F0FDF4" CornerRadius="8" Padding="15" Margin="0 0 10 0" Grid.Column="1">
                                    <StackPanel>
                                        <TextBlock Text="合格数量" Foreground="#666" FontSize="12"/>
                                        <TextBlock Text="0" Foreground="#10B981" FontSize="24" FontWeight="Bold"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#FEF2F2" CornerRadius="8" Padding="15" Margin="0 0 10 0" Grid.Column="2">
                                    <StackPanel>
                                        <TextBlock Text="不合格数量" Foreground="#666" FontSize="12"/>
                                        <TextBlock Text="0" Foreground="#EF4444" FontSize="24" FontWeight="Bold"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#FFFBEB" CornerRadius="8" Padding="15" Grid.Column="3">
                                    <StackPanel>
                                        <TextBlock Text="合格率" Foreground="#666" FontSize="12"/>
                                        <TextBlock Text="0%" Foreground="#F59E0B" FontSize="24" FontWeight="Bold"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- 右侧控制面板 -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Margin="0 0 0 0">
                <StackPanel>
                    <!-- 相机连接信息 -->
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="相机连接信息" FontSize="14" FontWeight="Bold" Foreground="#12142D" Margin="0 0 0 15"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="序列号:" Foreground="#666" Margin="0 0 0 8"/>
                                <TextBlock x:Name="SerialNoText" Grid.Row="0" Grid.Column="1" Text="待配置" Foreground="#12142D" Margin="0 0 0 8"/>
                                <TextBlock Grid.Row="1" Text="IP:" Foreground="#666" Margin="0 0 0 8"/>
                                <TextBlock x:Name="IpText" Grid.Row="1" Grid.Column="1" Text="待配置" Foreground="#12142D" Margin="0 0 0 8"/>
                                <TextBlock Grid.Row="2" Text="分辨率:" Foreground="#666" Margin="0 0 0 8"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="待获取" Foreground="#12142D" Margin="0 0 0 8"/>
                                <TextBlock Grid.Row="3" Text="状态:" Foreground="#666"/>
                                <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Fill="#EF4444" Margin="0 0 5 0"/>
                                    <TextBlock x:Name="ConnectionStatusText" Text="未连接" Foreground="#EF4444"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- 相机控制 -->
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="相机控制" FontSize="14" FontWeight="Bold" Foreground="#12142D" Margin="0 0 0 15"/>
                            <Button x:Name="BtnConnect" Content="连接相机" Style="{StaticResource ActionButton}" Margin="0 0 0 10" Click="BtnConnect_Click"/>
                            <Button x:Name="BtnStartGrab" Content="开始采集" Background="#10B981" Style="{StaticResource ActionButton}" Margin="0 0 0 10" Click="BtnStartGrab_Click" IsEnabled="False"/>
                            <Button x:Name="BtnStopGrab" Content="停止采集" Background="#F59E0B" Style="{StaticResource ActionButton}" Margin="0 0 0 10" Click="BtnStopGrab_Click" IsEnabled="False"/>
                            <Button x:Name="BtnDisconnect" Content="断开连接" Background="#6B7280" Style="{StaticResource ActionButton}" Click="BtnDisconnect_Click" IsEnabled="False"/>
                        </StackPanel>
                    </Border>

                    <!-- 曝光参数 -->
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="曝光参数" FontSize="14" FontWeight="Bold" Foreground="#12142D" Margin="0 0 0 15"/>
                            <TextBlock Text="曝光时间 (μs)" Foreground="#666" Margin="0 0 0 5"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="ExposureSlider" Minimum="100" Maximum="5000" Value="1000" VerticalAlignment="Center" ValueChanged="ExposureSlider_ValueChanged"/>
                                <TextBlock Grid.Column="1" x:Name="ExposureValueText" Text="1000" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="增益" Foreground="#666" Margin="0 15 0 5"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="GainSlider" Minimum="0" Maximum="20" Value="5" VerticalAlignment="Center" ValueChanged="GainSlider_ValueChanged"/>
                                <TextBlock Grid.Column="1" x:Name="GainValueText" Text="5.0" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- 检测参数 -->
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="检测参数" FontSize="14" FontWeight="Bold" Foreground="#12142D" Margin="0 0 0 15"/>
                            <TextBlock Text="ROI X" Foreground="#666" Margin="0 0 0 5"/>
                            <TextBox x:Name="RoiXText" Text="100"/>
                            <TextBlock Text="ROI Y" Foreground="#666" Margin="0 5 0 5"/>
                            <TextBox x:Name="RoiYText" Text="100"/>
                            <TextBlock Text="ROI Width" Foreground="#666" Margin="0 5 0 5"/>
                            <TextBox x:Name="RoiWidthText" Text="500"/>
                            <TextBlock Text="ROI Height" Foreground="#666" Margin="0 5 0 5"/>
                            <TextBox x:Name="RoiHeightText" Text="500"/>
                        </StackPanel>
                    </Border>

                    <!-- 操作日志 -->
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <Grid Margin="0 0 0 10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="操作日志" FontSize="14" FontWeight="Bold" Foreground="#12142D"/>
                                <Button Grid.Column="1" Content="清空" Foreground="#666" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnClearLog_Click"/>
                            </Grid>
                            <Border Background="#1E2142" CornerRadius="8" Padding="10" Height="150">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="LogPanel">
                                        <TextBlock Text="[系统就绪]" Foreground="#10B981" FontSize="11"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
