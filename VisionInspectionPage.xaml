<Page x:Class="WpfApp1.VisionInspectionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:wf="clr-namespace:System.Windows.Forms;assembly=System.Windows.Forms"
      mc:Ignorable="d"
      d:DesignHeight="800" d:DesignWidth="1200"
      Title="VisionInspectionPage"
      Loaded="VisionInspectionPage_Loaded"
      Unloaded="VisionInspectionPage_Unloaded">
    <Grid Background="#1A1A2E">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Border Grid.Row="0" Background="#16213E" BorderBrush="#0F3460" BorderThickness="0,0,0,1">
            <Grid Margin="15,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="StartCameraButton" Content="开始采集" Width="100" Height="36"
                            Background="#0F3460" Foreground="White" BorderThickness="0"
                            FontSize="14" FontWeight="SemiBold" Cursor="Hand"
                            Click="StartCameraButton_Click" Margin="0,0,10,0"/>
                    <Button x:Name="StopCameraButton" Content="停止采集" Width="100" Height="36"
                            Background="#533483" Foreground="White" BorderThickness="0"
                            FontSize="14" FontWeight="SemiBold" Cursor="Hand" IsEnabled="False"
                            Click="StopCameraButton_Click" Margin="0,0,10,0"/>
                    <Button x:Name="SaveImageButton" Content="保存图像" Width="100" Height="36"
                            Background="#0F3460" Foreground="White" BorderThickness="0"
                            FontSize="14" FontWeight="SemiBold" Cursor="Hand" IsEnabled="False"
                            Click="SaveImageButton_Click" Margin="0,0,10,0"/>
                    <Button x:Name="ClearLogButton" Content="清除日志" Width="100" Height="36"
                            Background="#0F3460" Foreground="White" BorderThickness="0"
                            FontSize="14" FontWeight="SemiBold" Cursor="Hand"
                            Click="ClearLogButton_Click"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock x:Name="FrameCountText" Text="帧数: 0" Foreground="#E94560"
                               FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,20,0"/>
                    <TextBlock x:Name="StatusText" Text="未连接" Foreground="#888888"
                               FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 相机显示区域 -->
        <Border Grid.Row="1" Background="#0D0D1A" Margin="10">
            <WindowsFormsHost x:Name="CameraDisplay" Margin="0"/>
        </Border>

        <!-- 底部日志区域 -->
        <Border Grid.Row="2" Background="#16213E" BorderBrush="#0F3460" BorderThickness="0,1,0,0">
            <TextBox x:Name="LogTextBox" Background="Transparent" Foreground="#AAAAAA"
                     BorderThickness="0" IsReadOnly="True" FontFamily="Consolas"
                     FontSize="12" VerticalScrollBarVisibility="Auto"
                     TextWrapping="Wrap" Margin="10"/>
        </Border>
    </Grid>
</Page>
