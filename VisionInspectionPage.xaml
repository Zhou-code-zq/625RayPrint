<Page x:Class="WpfApp1.VisionInspectionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="质检与监控">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="120"/>
        </Grid.RowDefinitions>
        
        <!-- 标题和按钮 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10">
            <TextBlock Text="视觉质检" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,20,0"/>
            <Button x:Name="StartCameraButton" Content="开始采集" Width="100" Height="30" Margin="5" Click="StartCameraButton_Click"/>
            <Button x:Name="SaveImageButton" Content="保存图像" Width="100" Height="30" Margin="5" Click="SaveImageButton_Click"/>
            <Button x:Name="ClearLogButton" Content="清空日志" Width="100" Height="30" Margin="5" Click="ClearLogButton_Click"/>
        </StackPanel>
        
        <!-- 相机图像显示区域 -->
        <Border Grid.Row="1" BorderBrush="Black" BorderThickness="1" Margin="10" Background="#333">
            <Viewbox>
                <Border Background="Black" Width="800" Height="600">
                    <Image x:Name="CameraImage" Stretch="None"/>
                </Border>
            </Viewbox>
        </Border>
        
        <!-- 状态栏 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="10,5">
            <TextBlock Text="状态：" VerticalAlignment="Center"/>
            <TextBlock x:Name="StatusText" Text="未连接" Foreground="Gray" VerticalAlignment="Center"/>
        </StackPanel>
        
        <!-- 操作日志 -->
        <GroupBox Grid.Row="3" Header="操作日志" Margin="10">
            <TextBox x:Name="LogTextBox" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="12"/>
        </GroupBox>
    </Grid>
</Page>
