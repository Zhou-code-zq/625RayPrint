<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="1400" Height="900"
        WindowStartupLocation="CenterScreen"
        MinWidth="1200" MinHeight="700"
        Background="#F0F2F5"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <!-- 颜色定义 -->
        <SolidColorBrush x:Key="PrimaryBrush" Color="#6366F1"/>
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#4F46E5"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#10B981"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#EF4444"/>
        <SolidColorBrush x:Key="DarkBgBrush" Color="#1E1E2E"/>
        <SolidColorBrush x:Key="SidebarBgBrush" Color="#252536"/>
        <SolidColorBrush x:Key="CardBgBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1F2937"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#6B7280"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#E5E7EB"/>

        <!-- 渐变定义 -->
        <LinearGradientBrush x:Key="ProgressGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#6366F1" Offset="0"/>
            <GradientStop Color="#A855F7" Offset="1"/>
        </LinearGradientBrush>

        <!-- 阴影效果 -->
        <DropShadowEffect x:Key="CardShadow" BlurRadius="20" ShadowDepth="5" Opacity="0.08" Color="Black"/>
        <DropShadowEffect x:Key="ButtonShadow" BlurRadius="10" ShadowDepth="3" Opacity="0.15" Color="#6366F1"/>

        <!-- 左侧标签按钮样式 -->
        <Style x:Key="TabItemStyle" TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20 0"/>
            <Setter Property="Margin" Value="0 4"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Grid>
                            <Border x:Name="Border"
                                    Background="{TemplateBinding Background}" 
                                    CornerRadius="8"
                                    Margin="8 0">
                                <ContentPresenter Content="{TemplateBinding Header}" 
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <!-- 选中指示条 -->
                            <Border x:Name="Indicator"
                                    Width="4"
                                    Height="24"
                                    Background="{StaticResource PrimaryBrush}"
                                    CornerRadius="2"
                                    HorizontalAlignment="Left"
                                    Margin="8 0 0 0"
                                    Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#2D2D44"/>
                                <Setter Property="Foreground" Value="#E5E7EB"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#3D3D5C"/>
                                <Setter TargetName="Indicator" Property="Visibility" Value="Visible"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 现代化按钮样式 -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20 12"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                Effect="{StaticResource ButtonShadow}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryDarkBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#D1D5DB"/>
                                <Setter TargetName="border" Property="Effect" Value="{x:Null}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 危险按钮样式 -->
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
        </Style>

        <!-- 成功按钮样式 -->
        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="{StaticResource SuccessBrush}"/>
        </Style>

        <!-- 警告按钮样式 -->
        <Style x:Key="WarningButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="{StaticResource WarningBrush}"/>
        </Style>

        <!-- 次要按钮样式 -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16 10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F3F4F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 标题栏按钮样式 -->
        <Style x:Key="TitleBarButton" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#374151"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
        </Style>

        <!-- 关闭按钮特殊样式 -->
        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource TitleBarButton}">
            <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#EF4444"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
        </Style>

        <!-- 数据卡片样式 -->
        <Style x:Key="ControlCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="0 0 16 16"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
        </Style>

        <!-- 状态指示灯 -->
        <Style x:Key="StatusLight" TargetType="Ellipse">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Height" Value="10"/>
            <Setter Property="Margin" Value="0 0 10 0"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="6" ShadowDepth="0" Opacity="0.5"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TabControl整体样式 -->
        <Style x:Key="MainTabControl" TargetType="TabControl">
            <Setter Property="Background" Value="{StaticResource SidebarBgBrush}"/>
            <Setter Property="TabStripPlacement" Value="Left"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="240"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- 左侧Tab头 -->
                            <Border Grid.Column="0" Background="{StaticResource SidebarBgBrush}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel Margin="0 60 0 0">
                                        <!-- Logo区域 -->
                                        <StackPanel Orientation="Horizontal" Margin="20 0 20 30">
                                            <Border Width="40" Height="40" CornerRadius="10" Background="{StaticResource PrimaryBrush}">
                                                <TextBlock Text="625" Foreground="White" FontSize="14" FontWeight="Bold" 
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Margin="12 0 0 0" VerticalAlignment="Center">
                                                <TextBlock Text="曲面打印" Foreground="White" FontSize="15" FontWeight="Bold"/>
                                                <TextBlock Text="控制系统 v1.0" Foreground="#6B7280" FontSize="11"/>
                                            </StackPanel>
                                        </StackPanel>
                                    <StackPanel IsItemsHost="True"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                            <!-- 右侧Tab内容 -->
                            <Grid Grid.Column="1" Background="#F0F2F5">
                                <ContentPresenter Content="{TemplateBinding SelectedContent}"/>
                            </Grid>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 进度条样式 -->
        <Style x:Key="ModernProgressBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="8"/>
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" CornerRadius="4"/>
                            <Border x:Name="PART_Track"/>
                            <Border x:Name="PART_Indicator" 
                                    Background="{StaticResource ProgressGradient}"
                                    CornerRadius="4"
                                    HorizontalAlignment="Left"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- 窗口圆角容器 -->
    <Border CornerRadius="10" Background="White" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 自定义标题栏 -->
            <Border Grid.Row="0" Background="{StaticResource DarkBgBrush}" CornerRadius="10 10 0 0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 拖拽区域 + 标题 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="15 0 0 0" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" Fill="#10B981" Margin="0 0 8 0"/>
                        <TextBlock Text="系统运行中" Foreground="#9CA3AF" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- 窗口控制按钮 -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="BtnMinimize" Style="{StaticResource TitleBarButton}" Content="─" Click="BtnMinimize_Click"/>
                        <Button x:Name="BtnMaximize" Style="{StaticResource TitleBarButton}" Content="☐" Click="BtnMaximize_Click"/>
                        <Button x:Name="BtnClose" Style="{StaticResource CloseButton}" Content="X" Click="BtnClose_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 主TabControl -->
            <TabControl Grid.Row="1" Style="{StaticResource MainTabControl}">
                <!-- 1. 流程总览标签页 -->
                <TabItem Style="{StaticResource TabItemStyle}">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="1" Width="24" FontSize="14" FontWeight="Bold"/>
                            <TextBlock Text="流程总览" Margin="8 0 0 0"/>
                        </StackPanel>
                    </TabItem.Header>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="320"/>
                            </Grid.ColumnDefinitions>

                            <!-- 顶部状态概览 -->
                            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource ControlCard}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 当前工序 -->
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="当前工序" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                        <TextBlock x:Name="TxtCurrentProcess" Text="转移打印" Foreground="{StaticResource TextPrimaryBrush}" FontSize="20" FontWeight="Bold" Margin="0 4 0 0"/>
                                        <Border Background="#DCFCE7" CornerRadius="4" Padding="6 2" Margin="0 8 0 0" HorizontalAlignment="Left">
                                            <TextBlock Text="运行中" Foreground="#16A34A" FontSize="11"/>
                                        </Border>
                                    </StackPanel>

                                    <!-- 打印进度 -->
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="打印进度" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                        <Grid Margin="0 4 0 0">
                                            <ProgressBar x:Name="ProgressBarPrint" Value="65" Style="{StaticResource ModernProgressBar}" Height="10"/>
                                        </Grid>
                                        <TextBlock x:Name="TxtProgress" Text="65%" Foreground="{StaticResource PrimaryBrush}" FontSize="14" FontWeight="SemiBold" Margin="0 6 0 0"/>
                                    </StackPanel>

                                    <!-- 已完成批次 -->
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="已完成批次" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                        <StackPanel Orientation="Horizontal" Margin="0 4 0 0">
                                            <TextBlock x:Name="TxtCompletedBatch" Text="128" Foreground="{StaticResource TextPrimaryBrush}" FontSize="20" FontWeight="Bold"/>
                                            <TextBlock Text=" / 200" Foreground="{StaticResource TextSecondaryBrush}" FontSize="14" VerticalAlignment="Bottom" Margin="0 0 0 3"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- 运行时长 -->
                                    <StackPanel Grid.Column="3">
                                        <TextBlock Text="运行时长" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                        <TextBlock x:Name="TxtRunTime" Text="03:45:22" Foreground="{StaticResource TextPrimaryBrush}" FontSize="20" FontWeight="Bold" Margin="0 4 0 0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- 工艺流程总览 -->
                            <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource ControlCard}">
                                <StackPanel>
                                    <Grid>
                                        <TextBlock Text="工艺流程总览" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock HorizontalAlignment="Right" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12">
                                            <Run Text="步骤 "/>
                                            <Run x:Name="TxtCurrentStep" Text="5" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                                            <Run Text=" / 7"/>
                                        </TextBlock>
                                    </Grid>

                                    <!-- 水平流程图 -->
                                    <Border Background="#F9FAFB" CornerRadius="12" Padding="20" Margin="0 20 0 0">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- 流程步骤 -->
                                            <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                                <StackPanel Orientation="Horizontal">
                                                    <!-- 步骤1: Z轴粗定位 -->
                                                    <StackPanel Width="140" Margin="0 0 20 0">
                                                        <Border Background="#6366F1" CornerRadius="8" Padding="12" MinHeight="60">
                                                            <TextBlock Text="Z轴粗定位" Foreground="White" TextAlignment="Center" TextWrapping="Wrap" FontWeight="Medium"/>
                                                        </Border>
                                                        <TextBlock Text="1" Foreground="#6366F1" FontWeight="Bold" HorizontalAlignment="Center" Margin="0 8 0 0"/>
                                                    </StackPanel>

                                                    <Path Stroke="#D1D5DB" StrokeThickness="2" Data="M 0,20 L 20,20" Margin="0 20 20 0" VerticalAlignment="Top"/>

                                                    <!-- 步骤2: 共焦位移传感器 -->
                                                    <StackPanel Width="140" Margin="0 0 20 0">
                                                        <Border Background="#6366F1" CornerRadius="8" Padding="12" MinHeight="60">
                                                            <TextBlock Text="共焦位移传感器" Foreground="White" TextAlignment="Center" TextWrapping="Wrap" FontWeight="Medium"/>
                                                        </Border>
                                                        <TextBlock Text="2" Foreground="#6366F1" FontWeight="Bold" HorizontalAlignment="Center" Margin="0 8 0 0"/>
                                                    </StackPanel>

                                                    <Path Stroke="#D1D5DB" StrokeThickness="2" Data="M 0,20 L 20,20" Margin="0 20 20 0" VerticalAlignment="Top"/>

                                                    <!-- 步骤3: 间隙控制 -->
                                                    <StackPanel Width="140" Margin="0 0 20 0">
                                                        <Border Background="#F59E0B" CornerRadius="8" Padding="12" MinHeight="60">
                                                            <TextBlock Text="间隙控制小于等于10μm" Foreground="White" TextAlignment="Center" TextWrapping="Wrap" FontWeight="Medium"/>
                                                        </Border>
                                                        <TextBlock Text="3" Foreground="#F59E0B" FontWeight="Bold" HorizontalAlignment="Center" Margin="0 8 0 0"/>
                                                    </StackPanel>

                                                    <Path Stroke="#D1D5DB" StrokeThickness="2" Data="M 0,20 L 20,20" Margin="0 20 20 0" VerticalAlignment="Top"/>

                                                    <!-- 步骤4: 视觉定位 -->
                                                    <StackPanel Width="140" Margin="0 0 20 0">
                                                        <Border Background="#10B981" CornerRadius="8" Padding="12" MinHeight="60">
                                                            <TextBlock Text="视觉定位补偿" Foreground="White" TextAlignment="Center" TextWrapping="Wrap" FontWeight="Medium"/>
                                                        </Border>
                                                        <TextBlock Text="4" Foreground="#10B981" FontWeight="Bold" HorizontalAlignment="Center" Margin="0 8 0 0"/>
                                                    </StackPanel>

                                                    <Path Stroke="#D1D5DB" StrokeThickness="2" Data="M 0,20 L 20,20" Margin="0 20 20 0" VerticalAlignment="Top"/>

                                                    <!-- 步骤5: 振镜补偿 -->
                                                    <StackPanel Width="140" Margin="0 0 20 0">
                                                        <Border Background="#10B981" CornerRadius="8" Padding="12" MinHeight="60">
                                                            <TextBlock Text="振镜补偿" Foreground="White" TextAlignment="Center" TextWrapping="Wrap" FontWeight="Medium"/>
                                                        </Border>
                                                        <TextBlock Text="5" Foreground="#10B981" FontWeight="Bold" HorizontalAlignment="Center" Margin="0 8 0 0"/>
                                                    </StackPanel>

                                                    <Path Stroke="#D1D5DB" StrokeThickness="2" Data="M 0,20 L 20,20" Margin="0 20 20 0" VerticalAlignment="Top"/>

                                                    <!-- 步骤6: 图像处理 -->
                                                    <StackPanel Width="140" Margin="0 0 20 0">
                                                        <Border Background="#10B981" CornerRadius="8" Padding="12" MinHeight="60">
                                                            <TextBlock Text="图像处理" Foreground="White" TextAlignment="Center" TextWrapping="Wrap" FontWeight="Medium"/>
                                                        </Border>
                                                        <TextBlock Text="6" Foreground="#10B981" FontWeight="Bold" HorizontalAlignment="Center" Margin="0 8 0 0"/>
                                                    </StackPanel>

                                                    <Path Stroke="#D1D5DB" StrokeThickness="2" Data="M 0,20 L 20,20" Margin="0 20 20 0" VerticalAlignment="Top"/>

                                                    <!-- 步骤7: 转移打印 -->
                                                    <StackPanel Width="140">
                                                        <Border Background="#10B981" CornerRadius="8" Padding="12" MinHeight="60">
                                                            <TextBlock Text="转移打印" Foreground="White" TextAlignment="Center" TextWrapping="Wrap" FontWeight="Medium"/>
                                                        </Border>
                                                        <TextBlock Text="7" Foreground="#10B981" FontWeight="Bold" HorizontalAlignment="Center" Margin="0 8 0 0"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </ScrollViewer>

                                            <!-- 图例 -->
                                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0 20 0 0" HorizontalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Margin="0 0 24 0">
                                                    <Border Width="12" Height="12" Background="#6366F1" CornerRadius="2"/>
                                                    <TextBlock Text="已完成" Foreground="{StaticResource TextSecondaryBrush}" Margin="8 0 0 0" FontSize="12"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0 0 24 0">
                                                    <Border Width="12" Height="12" Background="#F59E0B" CornerRadius="2"/>
                                                    <TextBlock Text="进行中" Foreground="{StaticResource TextSecondaryBrush}" Margin="8 0 0 0" FontSize="12"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Width="12" Height="12" Background="#10B981" CornerRadius="2"/>
                                                    <TextBlock Text="待执行" Foreground="{StaticResource TextSecondaryBrush}" Margin="8 0 0 0" FontSize="12"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- 关键工艺参数监控 -->
                            <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource ControlCard}">
                                <StackPanel>
                                    <TextBlock Text="关键工艺参数监控" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0 0 0 16"/>
                                    <UniformGrid Columns="4" Rows="1">
                                        <!-- 打印间隙 -->
                                        <Border Background="#EEF2FF" CornerRadius="12" Padding="16" Margin="0 0 12 0">
                                            <StackPanel>
                                                <Grid>
                                                    <TextBlock Text="打印间隙" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                                    <Ellipse Width="8" Height="8" Fill="#10B981" HorizontalAlignment="Right"/>
                                                </Grid>
                                                <TextBlock x:Name="TxtGap" Text="8.2 um" Foreground="#6366F1" FontSize="22" FontWeight="Bold" Margin="0 8 0 4"/>
                                                <TextBlock Text="目标小于等于10 um" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- 吸附气压 -->
                                        <Border Background="#ECFDF5" CornerRadius="12" Padding="16" Margin="0 0 12 0">
                                            <StackPanel>
                                                <Grid>
                                                    <TextBlock Text="吸附气压" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                                    <Ellipse Width="8" Height="8" Fill="#10B981" HorizontalAlignment="Right"/>
                                                </Grid>
                                                <TextBlock x:Name="TxtPressure" Text="-85 kPa" Foreground="#10B981" FontSize="22" FontWeight="Bold" Margin="0 8 0 4"/>
                                                <TextBlock Text="正常-80~-90 kPa" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- 激光功率 -->
                                        <Border Background="#FFFBEB" CornerRadius="12" Padding="16" Margin="0 0 12 0">
                                            <StackPanel>
                                                <Grid>
                                                    <TextBlock Text="激光功率" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                                    <Ellipse Width="8" Height="8" Fill="#F59E0B" HorizontalAlignment="Right"/>
                                                </Grid>
                                                <TextBlock x:Name="TxtLaserPower" Text="75%" Foreground="#F59E0B" FontSize="22" FontWeight="Bold" Margin="0 8 0 4"/>
                                                <TextBlock Text="当前中功率" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- 卷料长度 -->
                                        <Border Background="#F9FAFB" CornerRadius="12" Padding="16">
                                            <StackPanel>
                                                <Grid>
                                                    <TextBlock Text="卷料长度" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                                    <Ellipse Width="8" Height="8" Fill="#6366F1" HorizontalAlignment="Right"/>
                                                </Grid>
                                                <TextBlock x:Name="TxtRollLength" Text="1250 mm" Foreground="{StaticResource TextPrimaryBrush}" FontSize="22" FontWeight="Bold" Margin="0 8 0 4"/>
                                                <TextBlock Text="编码器控制" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>
                                </StackPanel>
                            </Border>

                            <!-- 右侧监控面板 -->
                            <StackPanel Grid.Row="0" Grid.RowSpan="3" Grid.Column="1">
                                <!-- 设备状态监控 -->
                                <Border Style="{StaticResource ControlCard}">
                                    <StackPanel>
                                        <TextBlock Text="设备状态监控" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0 0 0 16"/>

                                        <!-- Z轴定位模块 -->
                                        <Grid Margin="0 0 0 12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Z轴定位模块" Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <Ellipse Style="{StaticResource StatusLight}" Fill="{StaticResource SuccessBrush}"/>
                                                <TextBlock Text="正常" Foreground="{StaticResource SuccessBrush}" FontSize="12"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- 视觉定位模块 -->
                                        <Grid Margin="0 0 0 12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="视觉定位模块" Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <Ellipse Style="{StaticResource StatusLight}" Fill="{StaticResource SuccessBrush}"/>
                                                <TextBlock Text="正常" Foreground="{StaticResource SuccessBrush}" FontSize="12"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- 激光打印模块 -->
                                        <Grid Margin="0 0 0 12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="激光打印模块" Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <Ellipse Style="{StaticResource StatusLight}" Fill="{StaticResource SuccessBrush}"/>
                                                <TextBlock Text="正常" Foreground="{StaticResource SuccessBrush}" FontSize="12"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- 热固化平台 -->
                                        <Grid Margin="0 0 0 12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="热固化平台" Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <Ellipse Style="{StaticResource StatusLight}" Fill="{StaticResource SuccessBrush}"/>
                                                <TextBlock Text="正常" Foreground="{StaticResource SuccessBrush}" FontSize="12"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- 卷料伺服驱动 -->
                                        <Grid Margin="0 0 0 12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="卷料伺服驱动" Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <Ellipse Style="{StaticResource StatusLight}" Fill="{StaticResource WarningBrush}"/>
                                                <TextBlock Text="待机" Foreground="{StaticResource WarningBrush}" FontSize="12"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- 吸附平台 -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="吸附平台" Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <Ellipse Style="{StaticResource StatusLight}" Fill="{StaticResource SuccessBrush}"/>
                                                <TextBlock Text="正常" Foreground="{StaticResource SuccessBrush}" FontSize="12"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- 系统日志 -->
                                <Border Style="{StaticResource ControlCard}">
                                    <StackPanel>
                                        <Grid Margin="0 0 0 12">
                                            <TextBlock Text="系统日志" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <Button Content="清空" Style="{StaticResource SecondaryButton}" Padding="8 4" FontSize="11" 
                                                    HorizontalAlignment="Right" Click="BtnClearLog_Click"/>
                                        </Grid>
                                        <Border Background="#1E293B" CornerRadius="8" Padding="12" MaxHeight="200">
                                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                <StackPanel x:Name="LogPanel">
                                                    <TextBlock Text="[14:32:15] 间隙检测通过，当前8.2um" Foreground="#10B981" FontSize="11" FontFamily="Consolas"/>
                                                    <TextBlock Text="[14:32:10] 视觉定位完成，偏差补偿OK" Foreground="#10B981" FontSize="11" FontFamily="Consolas" Margin="0 6 0 0"/>
                                                    <TextBlock Text="[14:32:05] 振镜补偿参数加载完成" Foreground="#F59E0B" FontSize="11" FontFamily="Consolas" Margin="0 6 0 0"/>
                                                    <TextBlock Text="[14:31:58] 转移打印开始执行" Foreground="#6366F1" FontSize="11" FontFamily="Consolas" Margin="0 6 0 0"/>
                                                    <TextBlock Text="[14:31:45] 供料平台就绪，等待信号" Foreground="#9CA3AF" FontSize="11" FontFamily="Consolas" Margin="0 6 0 0"/>
                                                    <TextBlock Text="[14:31:30] 激光模块预热完成" Foreground="#10B981" FontSize="11" FontFamily="Consolas" Margin="0 6 0 0"/>
                                                </StackPanel>
                                            </ScrollViewer>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- 快捷操作 -->
                                <Border Style="{StaticResource ControlCard}">
                                    <StackPanel>
                                        <TextBlock Text="快捷操作" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0 0 0 16"/>

                                        <Button x:Name="BtnStartPrint" Style="{StaticResource SuccessButton}" Content="开始打印批次" Margin="0 0 0 10" 
                                                Click="BtnStartPrint_Click"/>
                                        <Button x:Name="BtnPausePrint" Style="{StaticResource WarningButton}" Content="暂停打印" Margin="0 0 0 10" 
                                                Click="BtnPausePrint_Click"/>
                                        <Button x:Name="BtnEmergencyStop" Style="{StaticResource DangerButton}" Content="紧急停止" Margin="0 0 0 10" 
                                                Click="BtnEmergencyStop_Click"/>
                                        <Button x:Name="BtnDebug" Style="{StaticResource ModernButton}" Content="停机调试参数" 
                                                Click="BtnDebug_Click"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <!-- 2. 运动控制标签页 -->
                <TabItem Style="{StaticResource TabItemStyle}">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="2" Width="24" FontSize="14" FontWeight="Bold"/>
                            <TextBlock Text="运动控制" Margin="8 0 0 0"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Border Background="White" CornerRadius="16" Margin="24" Padding="24" Effect="{StaticResource CardShadow}">
                        <StackPanel>
                            <TextBlock Text="运动控制模块" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0 0 0 20"/>

                            <!-- Z轴控制 -->
                            <Border Background="#EEF2FF" CornerRadius="12" Padding="20" Margin="0 0 0 16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Z轴位置控制" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="共焦位移传感器联动" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0 4 0 0"/>
                                    </StackPanel>
                                    <Slider x:Name="SliderZAxis" Grid.Column="1" Minimum="0" Maximum="100" Value="50" 
                                            VerticalAlignment="Center" Margin="20 0"/>
                                    <TextBlock Grid.Column="2" Text="50.0 mm" FontSize="16" FontWeight="Bold" 
                                               Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>

                            <!-- 伺服控制 -->
                            <Border Background="#ECFDF5" CornerRadius="12" Padding="20" Margin="0 0 0 16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="卷料伺服驱动" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="编码器速度反馈" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0 4 0 0"/>
                                    </StackPanel>
                                    <Slider x:Name="SliderServo" Grid.Column="1" Minimum="0" Maximum="100" Value="75" 
                                            VerticalAlignment="Center" Margin="20 0"/>
                                    <TextBlock Grid.Column="2" Text="75 rpm" FontSize="16" FontWeight="Bold" 
                                               Foreground="{StaticResource SuccessBrush}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>

                            <!-- 定位按钮 -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 20 0 0">
                                <Button Style="{StaticResource ModernButton}" Content="归零定位" Margin="0 0 12 0"/>
                                <Button Style="{StaticResource SecondaryButton}" Content="保存参数" Margin="0 0 12 0"/>
                                <Button Style="{StaticResource WarningButton}" Content="急停复位"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </TabItem>

                <!-- 3. 打印控制标签页 -->
                <TabItem Style="{StaticResource TabItemStyle}">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="3" Width="24" FontSize="14" FontWeight="Bold"/>
                            <TextBlock Text="打印控制" Margin="8 0 0 0"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Border Background="White" CornerRadius="16" Margin="24" Padding="24" Effect="{StaticResource CardShadow}">
                        <StackPanel>
                            <TextBlock Text="打印控制模块" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0 0 0 20"/>

                            <!-- 激光功率控制 -->
                            <Border Background="#FFFBEB" CornerRadius="12" Padding="20" Margin="0 0 0 16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="激光功率" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="当前档位中功率" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0 4 0 0"/>
                                    </StackPanel>
                                    <Slider x:Name="SliderLaserPower" Grid.Column="1" Minimum="0" Maximum="100" Value="75" 
                                            VerticalAlignment="Center" Margin="20 0"/>
                                    <TextBlock Grid.Column="2" Text="75%" FontSize="16" FontWeight="Bold" 
                                               Foreground="{StaticResource WarningBrush}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>

                            <!-- 打印批次设置 -->
                            <Border Background="#F9FAFB" CornerRadius="12" Padding="20" Margin="0 0 0 16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="打印批次设置" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="总批次数" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0 4 0 0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="-" Style="{StaticResource SecondaryButton}" Width="36" Padding="0"/>
                                        <TextBlock Text="200" FontSize="18" FontWeight="Bold" Margin="16 0" VerticalAlignment="Center"/>
                                        <Button Content="+" Style="{StaticResource SecondaryButton}" Width="36" Padding="0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- 操作按钮 -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 20 0 0">
                                <Button Style="{StaticResource SuccessButton}" Content="开始打印" Margin="0 0 12 0"/>
                                <Button Style="{StaticResource WarningButton}" Content="暂停" Margin="0 0 12 0"/>
                                <Button Style="{StaticResource DangerButton}" Content="停止"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </TabItem>

                <!-- 4. 平台与工艺标签页 -->
                <TabItem Style="{StaticResource TabItemStyle}">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="4" Width="24" FontSize="14" FontWeight="Bold"/>
                            <TextBlock Text="平台与工艺" Margin="8 0 0 0"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Border Background="White" CornerRadius="16" Margin="24" Padding="24" Effect="{StaticResource CardShadow}">
                        <StackPanel>
                            <TextBlock Text="平台与工艺模块" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0 0 0 20"/>

                            <!-- 吸附平台参数 -->
                            <Border Background="#ECFDF5" CornerRadius="12" Padding="20" Margin="0 0 0 16">
                                <StackPanel>
                                    <TextBlock Text="吸附平台参数" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0 0 0 12"/>
                                    <UniformGrid Columns="3">
                                        <StackPanel Margin="0 0 16 0">
                                            <TextBlock Text="目标气压(kPa)" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                            <TextBox x:Name="TxtTargetPressure" Text="-85" Padding="8" Margin="0 4 0 0"/>
                                        </StackPanel>
                                        <StackPanel Margin="0 0 16 0">
                                            <TextBlock Text="最小气压(kPa)" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                            <TextBox x:Name="TxtMinPressure" Text="-80" Padding="8" Margin="0 4 0 0"/>
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="最大气压(kPa)" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                            <TextBox x:Name="TxtMaxPressure" Text="-90" Padding="8" Margin="0 4 0 0"/>
                                        </StackPanel>
                                    </UniformGrid>
                                </StackPanel>
                            </Border>

                            <!-- 工艺参数 -->
                            <Border Background="#F9FAFB" CornerRadius="12" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="工艺参数配置" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0 0 0 12"/>
                                    <UniformGrid Columns="2">
                                        <StackPanel Margin="0 0 16 0">
                                            <TextBlock Text="目标间隙(um)" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                            <TextBox x:Name="TxtTargetGap" Text="10" Padding="8" Margin="0 4 0 0"/>
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="允许偏差(um)" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                            <TextBox x:Name="TxtGapDeviation" Text="2" Padding="8" Margin="0 4 0 0"/>
                                        </StackPanel>
                                    </UniformGrid>
                                </StackPanel>
                            </Border>

                            <Button Style="{StaticResource ModernButton}" Content="保存参数" HorizontalAlignment="Center" Margin="0 20 0 0"/>
                        </StackPanel>
                    </Border>
                </TabItem>

                <!-- 5. 质检与监控标签页 -->
                <TabItem Style="{StaticResource TabItemStyle}">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="5" Width="24" FontSize="14" FontWeight="Bold"/>
                            <TextBlock Text="质检与监控" Margin="8 0 0 0"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Border Background="White" CornerRadius="16" Margin="24" Padding="24" Effect="{StaticResource CardShadow}">
                        <StackPanel>
                            <TextBlock Text="质检与监控模块" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0 0 0 20"/>

                            <!-- 统计卡片 -->
                            <UniformGrid Columns="4" Margin="0 0 0 20">
                                <Border Background="#ECFDF5" CornerRadius="12" Padding="16" Margin="0 0 12 0">
                                    <StackPanel>
                                        <TextBlock Text="今日合格率" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                        <TextBlock Text="98.5%" Foreground="{StaticResource SuccessBrush}" FontSize="24" FontWeight="Bold"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#EEF2FF" CornerRadius="12" Padding="16" Margin="0 0 12 0">
                                    <StackPanel>
                                        <TextBlock Text="今日产量" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                        <TextBlock Text="1280" Foreground="{StaticResource PrimaryBrush}" FontSize="24" FontWeight="Bold"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#FFFBEB" CornerRadius="12" Padding="16" Margin="0 0 12 0">
                                    <StackPanel>
                                        <TextBlock Text="不良品数" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                        <TextBlock Text="19" Foreground="{StaticResource WarningBrush}" FontSize="24" FontWeight="Bold"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#F9FAFB" CornerRadius="12" Padding="16">
                                    <StackPanel>
                                        <TextBlock Text="设备稼动率" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                        <TextBlock Text="92%" Foreground="{StaticResource TextPrimaryBrush}" FontSize="24" FontWeight="Bold"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <!-- 图表占位 -->
                            <Border Background="#F9FAFB" CornerRadius="12" Padding="20" Height="250">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="质量趋势图表" Foreground="{StaticResource TextSecondaryBrush}" FontSize="14" HorizontalAlignment="Center"/>
                                    <TextBlock Text="图表组件待集成" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0 8 0 0" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </TabItem>

                <!-- 6. 退出系统 -->
                <TabItem Style="{StaticResource TabItemStyle}">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="6" Width="24" FontSize="14" FontWeight="Bold"/>
                            <TextBlock Text="退出系统" Margin="8 0 0 0"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Border Background="White" CornerRadius="16" Margin="24" Padding="24" Effect="{StaticResource CardShadow}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="确定要退出控制系统吗？" FontSize="18" FontWeight="Bold" 
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0 16 0 8" HorizontalAlignment="Center"/>
                            <TextBlock Text="请确保所有打印任务已完成保存" Foreground="{StaticResource TextSecondaryBrush}" 
                                       HorizontalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 24 0 0">
                                <Button Style="{StaticResource DangerButton}" Content="确认退出" Margin="0 0 12 0" Click="BtnExit_Click"/>
                                <Button Style="{StaticResource SecondaryButton}" Content="取消" Click="BtnCancelExit_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</Window>
