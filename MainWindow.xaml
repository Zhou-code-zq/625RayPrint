<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="1300" Height="850"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA"
        WindowState="Maximized"
        WindowStyle="None">

    <Window.Resources>
        <!-- 左侧标签按钮样式 -->
        <Style x:Key="TabItemStyle" TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#B0B8D4"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="15 0"/>
            <Setter Property="Margin" Value="0 5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Background="{TemplateBinding Background}" 
                                Width="220"
                                CornerRadius="5">
                            <ContentPresenter Content="{TemplateBinding Header}" 
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2A2D43"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#635BFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 数据卡片样式 -->
        <Style x:Key="ControlCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0 0 15 15"/>
        </Style>

        <!-- 状态指示灯 -->
        <Style x:Key="StatusLight" TargetType="Ellipse">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="Margin" Value="0 0 8 0"/>
        </Style>

        <!-- TabControl整体样式 -->
        <Style x:Key="MainTabControl" TargetType="TabControl">
            <Setter Property="Background" Value="#12142D"/>
            <Setter Property="TabStripPlacement" Value="Left"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ScrollViewer Grid.Column="0" 
                                          VerticalScrollBarVisibility="Auto"
                                          Background="#12142D"
                                          Margin="0">
                                <StackPanel IsItemsHost="True" Margin="20"/>
                            </ScrollViewer>
                            <Grid Grid.Column="1" Margin="20">
                                <ContentPresenter Content="{TemplateBinding SelectedContent}"/>
                            </Grid>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 标题栏按钮样式 -->
        <Style x:Key="TitleBarButton" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#374151"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 关闭按钮样式 -->
        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource TitleBarButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#EF4444"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 操作按钮基础样式 -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12 10"/>
            <Setter Property="Margin" Value="0 0 0 10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 次要按钮样式 -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12 8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F5F5F5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- 自定义标题栏 -->
        <Border Background="#12142D" Height="36" VerticalAlignment="Top" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧标题 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="15 0 0 0" VerticalAlignment="Center">
                    <TextBlock Text="曲面打印控制" Foreground="#9CA3AF" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 窗口控制按钮 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="_" Style="{StaticResource TitleBarButton}" Click="BtnMinimize_Click"/>
                    <Button x:Name="BtnMaximize" Content="☐" Style="{StaticResource TitleBarButton}" Click="BtnMaximize_Click"/>
                    <Button Content="X" Style="{StaticResource CloseButton}" Click="BtnClose_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 主TabControl -->
        <TabControl Style="{StaticResource MainTabControl}" Margin="0 36 0 0">
            <!-- 1. 流程总览标签页 -->
            <TabItem Margin="0,50,0,0" Style="{StaticResource TabItemStyle}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📊" Width="30"/>
                        <TextBlock Text="流程总览"/>
                    </StackPanel>
                </TabItem.Header>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左侧主内容 -->
                    <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- 顶部状态卡片 -->
                            <Border Background="White" CornerRadius="12" Padding="15" Margin="0 0 20 15">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="当前工序" Foreground="#666" FontSize="12"/>
                                        <TextBlock x:Name="TxtCurrentProcess" Text="转移打印" Foreground="#12142D" FontSize="18" FontWeight="Bold"/>
                                        <Border Background="#DCFCE7" CornerRadius="4" Padding="6 2" Margin="0 8 0 0" HorizontalAlignment="Left">
                                            <TextBlock Text="● 运行中" Foreground="#16A34A" FontSize="11"/>
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="打印进度" Foreground="#666" FontSize="12"/>
                                        <ProgressBar x:Name="ProgressBarPrint" Value="65" Background="#E5E7EB" Foreground="#635BFF" Height="8" Margin="0 8 0 0"/>
                                        <TextBlock x:Name="TxtProgress" Text="65%" Foreground="#635BFF" FontSize="12" Margin="0 4 0 0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="已完成批次" Foreground="#666" FontSize="12"/>
                                        <TextBlock x:Name="TxtCompletedBatch" Text="128 / 200" Foreground="#12142D" FontSize="18" FontWeight="Bold"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="3">
                                        <TextBlock Text="运行时长" Foreground="#666" FontSize="12"/>
                                        <TextBlock x:Name="TxtRunTime" Text="03:45:22" Foreground="#12142D" FontSize="18" FontWeight="Bold"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- 工艺流程总览 -->
                            <Border Style="{StaticResource ControlCard}">
                                <StackPanel>
                                    <Grid Margin="0 0 0 20">
                                        <TextBlock Text="工艺流程总览" FontSize="16" FontWeight="Bold" Foreground="#12142D"/>
                                        <TextBlock HorizontalAlignment="Right" Foreground="#666" FontSize="12">
                                            <Run Text="步骤 "/>
                                            <Run x:Name="TxtCurrentStep" Text="5" FontWeight="Bold" Foreground="#635BFF"/>
                                            <Run Text=" / 7"/>
                                        </TextBlock>
                                    </Grid>
                                    <Border Background="#F9FAFB" CornerRadius="8" Padding="20">
                                        <StackPanel HorizontalAlignment="Center">
                                            <!-- 步骤1 -->
                                            <Border Background="#6366F1" CornerRadius="5" Padding="10 5" Width="120">
                                                <TextBlock Text="Z轴粗定位" Foreground="White" TextAlignment="Center"/>
                                            </Border>
                                            <Path Stroke="#D1D5DB" StrokeThickness="2" Data="M 60,0 L 60,25" Margin="0 5"/>

                                            <!-- 步骤2 -->
                                            <Border Background="#6366F1" CornerRadius="5" Padding="10 5" Width="160">
                                                <TextBlock Text="共焦位移传感器" Foreground="White" TextAlignment="Center"/>
                                            </Border>
                                            <Path Stroke="#D1D5DB" StrokeThickness="2" Data="M 80,0 L 80,25" Margin="0 5"/>

                                            <!-- 步骤3 -->
                                            <Border Background="#F59E0B" CornerRadius="5" Padding="10 5" Width="140">
                                                <TextBlock Text="间隙控制≤10μm" Foreground="White" TextAlignment="Center"/>
                                            </Border>
                                            <Path Stroke="#D1D5DB" StrokeThickness="2" Data="M 70,0 L 70,25" Margin="0 5"/>

                                            <!-- 步骤4 -->
                                            <Border Background="#10B981" CornerRadius="5" Padding="10 5" Width="120">
                                                <TextBlock Text="视觉定位补偿" Foreground="White" TextAlignment="Center"/>
                                            </Border>
                                            <Path Stroke="#D1D5DB" StrokeThickness="2" Data="M 60,0 L 60,25" Margin="0 5"/>

                                            <!-- 步骤5 -->
                                            <Border Background="#10B981" CornerRadius="5" Padding="10 5" Width="100">
                                                <TextBlock Text="振镜补偿" Foreground="White" TextAlignment="Center"/>
                                            </Border>
                                            <Path Stroke="#D1D5DB" StrokeThickness="2" Data="M 50,0 L 50,25" Margin="0 5"/>

                                            <!-- 步骤6 -->
                                            <Border Background="#10B981" CornerRadius="5" Padding="10 5" Width="100">
                                                <TextBlock Text="图像处理" Foreground="White" TextAlignment="Center"/>
                                            </Border>
                                            <Path Stroke="#D1D5DB" StrokeThickness="2" Data="M 50,0 L 50,25" Margin="0 5"/>

                                            <!-- 步骤7 -->
                                            <Border Background="#10B981" CornerRadius="5" Padding="10 5" Width="100">
                                                <TextBlock Text="转移打印" Foreground="White" TextAlignment="Center"/>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <!-- 图例 -->
                                    <StackPanel Orientation="Horizontal" Margin="0 15 0 0" HorizontalAlignment="Center">
                                        <Border Width="12" Height="12" Background="#6366F1" CornerRadius="2" Margin="0 0 6 0"/>
                                        <TextBlock Text="已完成" Foreground="#666" FontSize="11" Margin="0 0 15 0"/>
                                        <Border Width="12" Height="12" Background="#F59E0B" CornerRadius="2" Margin="0 0 6 0"/>
                                        <TextBlock Text="进行中" Foreground="#666" FontSize="11" Margin="0 0 15 0"/>
                                        <Border Width="12" Height="12" Background="#10B981" CornerRadius="2" Margin="0 0 6 0"/>
                                        <TextBlock Text="待执行" Foreground="#666" FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- 关键工艺参数监控 -->
                            <Border Style="{StaticResource ControlCard}">
                                <StackPanel>
                                    <TextBlock Text="关键工艺参数监控" FontSize="16" FontWeight="Bold" Foreground="#12142D" Margin="0 0 0 15"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Background="#F0F4FF" CornerRadius="8" Padding="15" Margin="0 0 10 0">
                                            <StackPanel>
                                                <Grid>
                                                    <TextBlock Text="打印间隙" Foreground="#666" FontSize="12"/>
                                                    <Ellipse Width="8" Height="8" Fill="#10B981" HorizontalAlignment="Right"/>
                                                </Grid>
                                                <TextBlock x:Name="TxtGap" Text="8.2 μm" Foreground="#635BFF" FontSize="20" FontWeight="Bold" Margin="0 5 0 0"/>
                                                <TextBlock Text="目标: ≤10 μm" Foreground="#666" FontSize="10"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="#ECFDF5" CornerRadius="8" Padding="15" Margin="0 0 10 0" Grid.Column="1">
                                            <StackPanel>
                                                <Grid>
                                                    <TextBlock Text="吸附气压" Foreground="#666" FontSize="12"/>
                                                    <Ellipse Width="8" Height="8" Fill="#10B981" HorizontalAlignment="Right"/>
                                                </Grid>
                                                <TextBlock x:Name="TxtPressure" Text="-85 kPa" Foreground="#10B981" FontSize="20" FontWeight="Bold" Margin="0 5 0 0"/>
                                                <TextBlock Text="正常: -80~-90 kPa" Foreground="#666" FontSize="10"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="#FFFBEB" CornerRadius="8" Padding="15" Margin="0 0 10 0" Grid.Column="2">
                                            <StackPanel>
                                                <Grid>
                                                    <TextBlock Text="激光功率" Foreground="#666" FontSize="12"/>
                                                    <Ellipse Width="8" Height="8" Fill="#F59E0B" HorizontalAlignment="Right"/>
                                                </Grid>
                                                <TextBlock x:Name="TxtLaserPower" Text="75%" Foreground="#F59E0B" FontSize="20" FontWeight="Bold" Margin="0 5 0 0"/>
                                                <TextBlock Text="当前: 中功率" Foreground="#666" FontSize="10"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="#F9FAFB" CornerRadius="8" Padding="15" Grid.Column="3">
                                            <StackPanel>
                                                <Grid>
                                                    <TextBlock Text="卷料长度" Foreground="#666" FontSize="12"/>
                                                    <Ellipse Width="8" Height="8" Fill="#635BFF" HorizontalAlignment="Right"/>
                                                </Grid>
                                                <TextBlock x:Name="TxtRollLength" Text="1250 mm" Foreground="#12142D" FontSize="20" FontWeight="Bold" Margin="0 5 0 0"/>
                                                <TextBlock Text="编码器控制" Foreground="#666" FontSize="10"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- 右侧监控面板 -->
                    <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Margin="20 0 0 0">
                        <StackPanel>
                            <!-- 设备状态监控 -->
                            <Border Style="{StaticResource ControlCard}">
                                <StackPanel>
                                    <TextBlock Text="设备状态监控" FontSize="14" FontWeight="Bold" Foreground="#12142D" Margin="0 0 0 15"/>
                                    <StackPanel Orientation="Horizontal" Margin="0 0 0 10">
                                        <Ellipse Style="{StaticResource StatusLight}" Fill="#10B981"/>
                                        <TextBlock Text="Z轴定位模块" Foreground="#12142D"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0 0 0 10">
                                        <Ellipse Style="{StaticResource StatusLight}" Fill="#10B981"/>
                                        <TextBlock Text="视觉定位模块" Foreground="#12142D"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0 0 0 10">
                                        <Ellipse Style="{StaticResource StatusLight}" Fill="#10B981"/>
                                        <TextBlock Text="激光打印模块" Foreground="#12142D"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0 0 0 10">
                                        <Ellipse Style="{StaticResource StatusLight}" Fill="#10B981"/>
                                        <TextBlock Text="热固化平台" Foreground="#12142D"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0 0 0 10">
                                        <Ellipse Style="{StaticResource StatusLight}" Fill="#F59E0B"/>
                                        <TextBlock Text="卷料伺服驱动" Foreground="#12142D"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Style="{StaticResource StatusLight}" Fill="#10B981"/>
                                        <TextBlock Text="吸附平台" Foreground="#12142D"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- 系统日志 -->
                            <Border Style="{StaticResource ControlCard}">
                                <StackPanel>
                                    <Grid Margin="0 0 0 10">
                                        <TextBlock Text="系统日志" FontSize="14" FontWeight="Bold" Foreground="#12142D"/>
                                        <Button Content="清空" Style="{StaticResource SecondaryButton}" Padding="8 4" FontSize="11"
                                                HorizontalAlignment="Right" Click="BtnClearLog_Click"/>
                                    </Grid>
                                    <Border Background="#1E2142" CornerRadius="8" Padding="10" MaxHeight="180">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <StackPanel x:Name="LogPanel">
                                                <TextBlock Text="[14:32:15] 间隙检测通过，当前8.2μm" Foreground="#10B981" FontSize="11"/>
                                                <TextBlock Text="[14:32:10] 视觉定位完成，偏差补偿OK" Foreground="#10B981" FontSize="11" Margin="0 5 0 0"/>
                                                <TextBlock Text="[14:32:05] 振镜补偿参数加载完成" Foreground="#F59E0B" FontSize="11" Margin="0 5 0 0"/>
                                                <TextBlock Text="[14:31:58] 转移打印开始执行" Foreground="#635BFF" FontSize="11" Margin="0 5 0 0"/>
                                                <TextBlock Text="[14:31:45] 供料平台就绪，等待信号" Foreground="#666" FontSize="11" Margin="0 5 0 0"/>
                                                <TextBlock Text="[14:31:30] 激光模块预热完成" Foreground="#10B981" FontSize="11" Margin="0 5 0 0"/>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- 快捷操作 -->
                            <Border Style="{StaticResource ControlCard}">
                                <StackPanel>
                                    <TextBlock Text="快捷操作" FontSize="14" FontWeight="Bold" Foreground="#12142D" Margin="0 0 0 15"/>
                                    <Button x:Name="BtnStartPrint" Content="开始打印批次" Style="{StaticResource ActionButton}" Background="#10B981" Click="BtnStartPrint_Click"/>
                                    <Button x:Name="BtnPausePrint" Content="暂停打印" Style="{StaticResource ActionButton}" Background="#F59E0B" Click="BtnPausePrint_Click"/>
                                    <Button x:Name="BtnStopPrint" Content="停止打印" Style="{StaticResource ActionButton}" Background="#EF4444" Click="BtnStopPrint_Click"/>
                                    <Button x:Name="BtnDebug" Content="停机调试参数" Style="{StaticResource ActionButton}" Background="#635BFF" Click="BtnDebug_Click"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- 2. 运动控制标签页 -->
            <TabItem Style="{StaticResource TabItemStyle}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🎯" Width="30"/>
                        <TextBlock Text="运动控制"/>
                    </StackPanel>
                </TabItem.Header>
                <Border Background="White" CornerRadius="12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="运动控制模块" FontSize="20" FontWeight="Bold" Foreground="#12142D" Margin="0 0 0 20"/>

                        <!-- Z轴位置控制 -->
                        <Border Background="#F0F4FF" CornerRadius="8" Padding="20" Margin="0 0 0 15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Z轴位置控制" FontWeight="SemiBold" Foreground="#12142D"/>
                                    <TextBlock Text="共焦位移传感器联动" Foreground="#666" FontSize="11" Margin="0 4 0 0"/>
                                </StackPanel>
                                <Slider x:Name="SliderZAxis" Grid.Column="1" Minimum="0" Maximum="100" Value="50" VerticalAlignment="Center" Margin="20 0"/>
                                <TextBlock Grid.Column="2" Text="50.0 mm" FontSize="16" FontWeight="Bold" Foreground="#635BFF" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>

                        <!-- 伺服驱动控制 -->
                        <Border Background="#ECFDF5" CornerRadius="8" Padding="20" Margin="0 0 0 15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="卷料伺服驱动" FontWeight="SemiBold" Foreground="#12142D"/>
                                    <TextBlock Text="编码器速度反馈" Foreground="#666" FontSize="11" Margin="0 4 0 0"/>
                                </StackPanel>
                                <Slider x:Name="SliderServo" Grid.Column="1" Minimum="0" Maximum="100" Value="75" VerticalAlignment="Center" Margin="20 0"/>
                                <TextBlock Grid.Column="2" Text="75 rpm" FontSize="16" FontWeight="Bold" Foreground="#10B981" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 20 0 0">
                            <Button Content="归零定位" Style="{StaticResource ActionButton}" Background="#635BFF" Margin="0 0 12 0"/>
                            <Button Content="保存参数" Style="{StaticResource SecondaryButton}" Margin="0 0 12 0"/>
                            <Button Content="急停复位" Style="{StaticResource ActionButton}" Background="#EF4444"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- 3. 打印控制标签页 -->
            <TabItem Style="{StaticResource TabItemStyle}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🖨️" Width="30"/>
                        <TextBlock Text="打印控制"/>
                    </StackPanel>
                </TabItem.Header>
                <Border Background="White" CornerRadius="12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="打印控制模块" FontSize="20" FontWeight="Bold" Foreground="#12142D" Margin="0 0 0 20"/>

                        <!-- 激光功率控制 -->
                        <Border Background="#FFFBEB" CornerRadius="8" Padding="20" Margin="0 0 0 15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="激光功率" FontWeight="SemiBold" Foreground="#12142D"/>
                                    <TextBlock Text="当前档位: 中功率" Foreground="#666" FontSize="11" Margin="0 4 0 0"/>
                                </StackPanel>
                                <Slider x:Name="SliderLaser" Grid.Column="1" Minimum="0" Maximum="100" Value="75" VerticalAlignment="Center" Margin="20 0"/>
                                <TextBlock Grid.Column="2" Text="75%" FontSize="16" FontWeight="Bold" Foreground="#F59E0B" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>

                        <!-- 打印批次设置 -->
                        <Border Background="#F9FAFB" CornerRadius="8" Padding="20" Margin="0 0 0 15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="打印批次设置" FontWeight="SemiBold" Foreground="#12142D"/>
                                    <TextBlock Text="总批次数" Foreground="#666" FontSize="11" Margin="0 4 0 0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="-" Style="{StaticResource SecondaryButton}" Width="36" Padding="0"/>
                                    <TextBlock Text="200" FontSize="18" FontWeight="Bold" Margin="16 0" VerticalAlignment="Center"/>
                                    <Button Content="+" Style="{StaticResource SecondaryButton}" Width="36" Padding="0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 20 0 0">
                            <Button Content="开始打印" Style="{StaticResource ActionButton}" Background="#10B981" Margin="0 0 12 0"/>
                            <Button Content="暂停" Style="{StaticResource ActionButton}" Background="#F59E0B" Margin="0 0 12 0"/>
                            <Button Content="停止" Style="{StaticResource ActionButton}" Background="#EF4444"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- 4. 平台与工艺标签页 -->
            <TabItem Style="{StaticResource TabItemStyle}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔧" Width="30"/>
                        <TextBlock Text="平台与工艺"/>
                    </StackPanel>
                </TabItem.Header>
                <Border Background="White" CornerRadius="12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="平台与工艺模块" FontSize="20" FontWeight="Bold" Foreground="#12142D" Margin="0 0 0 20"/>

                        <!-- 吸附平台参数 -->
                        <Border Background="#ECFDF5" CornerRadius="8" Padding="20" Margin="0 0 0 15">
                            <StackPanel>
                                <TextBlock Text="吸附平台参数" FontWeight="SemiBold" Foreground="#12142D" Margin="0 0 0 12"/>
                                <UniformGrid Columns="3">
                                    <StackPanel Margin="0 0 15 0">
                                        <TextBlock Text="目标气压 (kPa)" Foreground="#666" FontSize="12"/>
                                        <TextBox x:Name="TxtTargetPressure" Text="-85" Padding="8" Margin="0 4 0 0"/>
                                    </StackPanel>
                                    <StackPanel Margin="0 0 15 0">
                                        <TextBlock Text="最小气压 (kPa)" Foreground="#666" FontSize="12"/>
                                        <TextBox x:Name="TxtMinPressure" Text="-80" Padding="8" Margin="0 4 0 0"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="最大气压 (kPa)" Foreground="#666" FontSize="12"/>
                                        <TextBox x:Name="TxtMaxPressure" Text="-90" Padding="8" Margin="0 4 0 0"/>
                                    </StackPanel>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <!-- 工艺参数 -->
                        <Border Background="#F9FAFB" CornerRadius="8" Padding="20">
                            <StackPanel>
                                <TextBlock Text="工艺参数配置" FontWeight="SemiBold" Foreground="#12142D" Margin="0 0 0 12"/>
                                <UniformGrid Columns="2">
                                    <StackPanel Margin="0 0 15 0">
                                        <TextBlock Text="目标间隙 (μm)" Foreground="#666" FontSize="12"/>
                                        <TextBox x:Name="TxtTargetGap" Text="10" Padding="8" Margin="0 4 0 0"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="允许偏差 (μm)" Foreground="#666" FontSize="12"/>
                                        <TextBox x:Name="TxtGapDeviation" Text="2" Padding="8" Margin="0 4 0 0"/>
                                    </StackPanel>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <Button Content="保存参数" Style="{StaticResource ActionButton}" Background="#635BFF" HorizontalAlignment="Center" Margin="0 20 0 0"/>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- 5. 质检与监控标签页 -->
            <TabItem Style="{StaticResource TabItemStyle}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✅" Width="30"/>
                        <TextBlock Text="质检与监控"/>
                    </StackPanel>
                </TabItem.Header>
                <Border Background="White" CornerRadius="12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="质检与监控模块" FontSize="20" FontWeight="Bold" Foreground="#12142D" Margin="0 0 0 20"/>

                        <!-- 统计卡片 -->
                        <UniformGrid Columns="4" Margin="0 0 0 20">
                            <Border Background="#ECFDF5" CornerRadius="8" Padding="15" Margin="0 0 10 0">
                                <StackPanel>
                                    <TextBlock Text="今日合格率" Foreground="#666" FontSize="12"/>
                                    <TextBlock Text="98.5%" Foreground="#10B981" FontSize="22" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#EEF2FF" CornerRadius="8" Padding="15" Margin="0 0 10 0">
                                <StackPanel>
                                    <TextBlock Text="今日产量" Foreground="#666" FontSize="12"/>
                                    <TextBlock Text="1280" Foreground="#635BFF" FontSize="22" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#FFFBEB" CornerRadius="8" Padding="15" Margin="0 0 10 0">
                                <StackPanel>
                                    <TextBlock Text="不良品数" Foreground="#666" FontSize="12"/>
                                    <TextBlock Text="19" Foreground="#F59E0B" FontSize="22" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#F9FAFB" CornerRadius="8" Padding="15">
                                <StackPanel>
                                    <TextBlock Text="设备稼动率" Foreground="#666" FontSize="12"/>
                                    <TextBlock Text="92%" Foreground="#12142D" FontSize="22" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- 图表占位 -->
                        <Border Background="#F9FAFB" CornerRadius="8" Padding="20" Height="200">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="质量趋势图表" Foreground="#666" FontSize="14" HorizontalAlignment="Center"/>
                                <TextBlock Text="(图表组件待集成)" Foreground="#999" FontSize="12" Margin="0 8 0 0" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- 6. 退出系统 -->
            <TabItem Style="{StaticResource TabItemStyle}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🚪" Width="30"/>
                        <TextBlock Text="退出系统"/>
                    </StackPanel>
                </TabItem.Header>
                <Border Background="White" CornerRadius="12" Padding="20">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="确定要退出控制系统吗？" FontSize="18" FontWeight="Bold" Foreground="#12142D" Margin="0 0 0 8" HorizontalAlignment="Center"/>
                        <TextBlock Text="请确保所有打印任务已完成或已保存" Foreground="#666" HorizontalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 24 0 0">
                            <Button Content="确认退出" Style="{StaticResource ActionButton}" Background="#EF4444" Margin="0 0 12 0" Click="BtnExit_Click"/>
                            <Button Content="取消" Style="{StaticResource SecondaryButton}" Click="BtnCancelExit_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </TabItem>
        </TabControl>

        <!-- 系统标题 -->
        <StackPanel Orientation="Horizontal" Margin="30 50 0 0" Panel.ZIndex="10">
            <TextBlock Text="⚙️" Foreground="#FF9D43" FontSize="20"/>
            <TextBlock Text=" 曲面打印控制" Foreground="White" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
