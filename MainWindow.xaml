<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="1300" Height="850"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA"
        WindowState="Maximized"
        
        xmlns:local="clr-namespace:WpfApp1"
        WindowStyle="None">

    <Window.Resources>
        <!-- 左侧标签按钮样式（复用并适配TabItem） -->
        <Style x:Key="TabItemStyle" TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#B0B8D4"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="15 0"/>
            <Setter Property="Margin" Value="0 5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Background="{TemplateBinding Background}" 
                                Width="220"
                                CornerRadius="5">
                            <ContentPresenter Content="{TemplateBinding Header}" 
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2A2D43"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#635BFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 数据卡片样式 -->
        <Style x:Key="ControlCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0 0 15 15"/>
        </Style>

        <!-- 状态指示灯 -->
        <Style x:Key="StatusLight" TargetType="Ellipse">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="Margin" Value="0 0 8 0"/>
        </Style>

        <!-- TabControl整体样式 -->
        <Style x:Key="MainTabControl" TargetType="TabControl">
            <Setter Property="Background" Value="#12142D"/>
            <Setter Property="TabStripPlacement" Value="Left"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- 左侧Tab头 -->
                            <ScrollViewer Grid.Column="0" 
                                          VerticalScrollBarVisibility="Auto"
                                          Background="#12142D"
                                          Margin="0">
                                <StackPanel IsItemsHost="True" Margin="20"/>
                            </ScrollViewer>
                            <!-- 右侧Tab内容 -->
                            <Grid Grid.Column="1" Margin="20">
                                <ContentPresenter Content="{TemplateBinding SelectedContent}"/>
                            </Grid>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid> 
        <!-- 主TabControl -->
        <TabControl Style="{StaticResource MainTabControl}">
            <!-- 1. 流程总览标签页 -->
            <TabItem Margin="0,50,0,0" Style="{StaticResource TabItemStyle}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📊" Width="30"/>
                        <TextBlock Text="流程总览"/>
                    </StackPanel>
                </TabItem.Header>

                <!-- 流程总览内容（原中间主内容区+右侧监控面板） -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左侧主内容 -->
                    <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Background="White" CornerRadius="12" Padding="15" Margin="0 0 20 15">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="当前工序" Foreground="#666" FontSize="12"/>
                                        <TextBlock Text="转移打印" Foreground="#12142D" FontSize="18" FontWeight="Bold"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="打印进度" Foreground="#666" FontSize="12"/>
                                        <ProgressBar Value="65" Background="#E5E7EB" Foreground="#635BFF" Height="8" Margin="0 5 0 0"/>
                                        <TextBlock Text="65%" Foreground="#635BFF" FontSize="12"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="已完成批次" Foreground="#666" FontSize="12"/>
                                        <TextBlock Text="128 / 200" Foreground="#12142D" FontSize="18" FontWeight="Bold"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="3">
                                        <TextBlock Text="运行时长" Foreground="#666" FontSize="12"/>
                                        <TextBlock Text="03:45:22" Foreground="#12142D" FontSize="18" FontWeight="Bold"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource ControlCard}">
                                <StackPanel>
                                    <TextBlock Text="工艺流程总览" FontSize="16" FontWeight="Bold" Foreground="#12142D" Margin="0 0 0 20"/>
                                    <Border Background="#F9FAFB" CornerRadius="8" Padding="20" Height="600">
                                        <StackPanel HorizontalAlignment="Center">
                                            <Border Background="#635BFF" CornerRadius="5" Padding="10 5" Width="120">
                                                <TextBlock Text="Z轴粗定位" Foreground="White" TextAlignment="Center"/>
                                            </Border>
                                            <Path Stroke="#635BFF" StrokeThickness="2" Data="M 90,0 L 90,30" Margin="0 5"/>

                                            <Border Background="#635BFF" CornerRadius="5" Padding="10 5" Width="180">
                                                <TextBlock Text="共焦位移传感器控制" Foreground="White" TextAlignment="Center"/>
                                            </Border>
                                            <Path Stroke="#635BFF" StrokeThickness="2" Data="M 90,0 L 90,30" Margin="0 5"/>

                                            <Border Background="#F59E0B" CornerRadius="5" Padding="10 5" Width="150">
                                                <TextBlock Text="间隙控制≤10μm" Foreground="White" TextAlignment="Center"/>
                                            </Border>
                                            <Path Stroke="#635BFF" StrokeThickness="2" Data="M 90,0 L 90,30" Margin="0 5"/>

                                            <Border Background="#10B981" CornerRadius="5" Padding="10 5" Width="150">
                                                <TextBlock Text="视觉定位补偿" Foreground="White" TextAlignment="Center"/>
                                            </Border>
                                            <Path Stroke="#10B981" StrokeThickness="2" Data="M 90,0 L 90,30" Margin="0 5"/>

                                            <Border Background="#10B981" CornerRadius="5" Padding="10 5" Width="100">
                                                <TextBlock Text="振镜补偿" Foreground="White" TextAlignment="Center"/>
                                            </Border>
                                            <Path Stroke="#10B981" StrokeThickness="2" Data="M 90,0 L 90,30" Margin="0 5"/>

                                            <Border Background="#10B981" CornerRadius="5" Padding="10 5" Width="100">
                                                <TextBlock Text="图像处理" Foreground="White" TextAlignment="Center"/>
                                            </Border>
                                            <Path Stroke="#10B981" StrokeThickness="2" Data="M 90,0 L 90,30" Margin="0 5"/>

                                            <Border Background="#10B981" CornerRadius="5" Padding="10 5" Width="120">
                                                <TextBlock Text="转移打印" Foreground="White" TextAlignment="Center"/>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource ControlCard}">
                                <StackPanel>
                                    <TextBlock Text="关键工艺参数监控" FontSize="16" FontWeight="Bold" Foreground="#12142D" Margin="0 0 0 15"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Background="#F0F4FF" CornerRadius="8" Padding="15" Margin="0 0 10 0">
                                            <StackPanel>
                                                <TextBlock Text="打印间隙" Foreground="#666" FontSize="12"/>
                                                <TextBlock Text="8.2 μm" Foreground="#635BFF" FontSize="20" FontWeight="Bold"/>
                                                <TextBlock Text="目标: ≤10 μm" Foreground="#666" FontSize="10"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="#F0F4FF" CornerRadius="8" Padding="15" Margin="0 0 10 0" Grid.Column="1">
                                            <StackPanel>
                                                <TextBlock Text="吸附气压" Foreground="#666" FontSize="12"/>
                                                <TextBlock Text="-85 kPa" Foreground="#10B981" FontSize="20" FontWeight="Bold"/>
                                                <TextBlock Text="正常范围: -80~-90 kPa" Foreground="#666" FontSize="10"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="#F0F4FF" CornerRadius="8" Padding="15" Margin="0 0 10 0" Grid.Column="2">
                                            <StackPanel>
                                                <TextBlock Text="激光功率" Foreground="#666" FontSize="12"/>
                                                <TextBlock Text="75%" Foreground="#F59E0B" FontSize="20" FontWeight="Bold"/>
                                                <TextBlock Text="当前档位: 中功率" Foreground="#666" FontSize="10"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="#F0F4FF" CornerRadius="8" Padding="15" Grid.Column="3">
                                            <StackPanel>
                                                <TextBlock Text="卷料长度" Foreground="#666" FontSize="12"/>
                                                <TextBlock Text="1250 mm" Foreground="#12142D" FontSize="20" FontWeight="Bold"/>
                                                <TextBlock Text="编码器控制中" Foreground="#666" FontSize="10"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- 右侧监控面板 -->
                    <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Margin="20 0 0 0">
                        <StackPanel>
                            <Border Style="{StaticResource ControlCard}">
                                <StackPanel>
                                    <TextBlock Text="设备状态监控" FontSize="14" FontWeight="Bold" Foreground="#12142D" Margin="0 0 15 15"/>
                                    <StackPanel Orientation="Horizontal" Margin="0 0 0 10">
                                        <Ellipse Style="{StaticResource StatusLight}" Fill="#10B981"/>
                                        <TextBlock Text="Z轴定位模块" Foreground="#12142D"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0 0 0 10">
                                        <Ellipse Style="{StaticResource StatusLight}" Fill="#10B981"/>
                                        <TextBlock Text="视觉定位模块" Foreground="#12142D"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0 0 0 10">
                                        <Ellipse Style="{StaticResource StatusLight}" Fill="#10B981"/>
                                        <TextBlock Text="激光打印模块" Foreground="#12142D"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0 0 0 10">
                                        <Ellipse Style="{StaticResource StatusLight}" Fill="#10B981"/>
                                        <TextBlock Text="热固化平台" Foreground="#12142D"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0 0 0 10">
                                        <Ellipse Style="{StaticResource StatusLight}" Fill="#F59E0B"/>
                                        <TextBlock Text="卷料伺服驱动" Foreground="#12142D"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Style="{StaticResource StatusLight}" Fill="#10B981"/>
                                        <TextBlock Text="吸附平台" Foreground="#12142D"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource ControlCard}">
                                <StackPanel>
                                    <TextBlock Text="系统日志" FontSize="14" FontWeight="Bold" Foreground="#12142D" Margin="0 0 15 0"/>
                                    <Border Background="#1E2142" CornerRadius="8" Padding="10" Height="200">
                                        <StackPanel>
                                            <TextBlock Text="[14:32:15] 间隙检测通过，当前8.2μm" Foreground="#10B981" FontSize="11"/>
                                            <TextBlock Text="[14:32:10] 视觉定位完成，偏差补偿OK" Foreground="#10B981" FontSize="11" Margin="0 5 0 0"/>
                                            <TextBlock Text="[14:32:05] 振镜补偿参数加载完成" Foreground="#F59E0B" FontSize="11" Margin="0 5 0 0"/>
                                            <TextBlock Text="[14:31:58] 转移打印开始执行" Foreground="#635BFF" FontSize="11" Margin="0 5 0 0"/>
                                            <TextBlock Text="[14:31:45] 供料平台就绪，等待信号" Foreground="#666" FontSize="11" Margin="0 5 0 0"/>
                                            <TextBlock Text="[14:31:30] 激光模块预热完成" Foreground="#10B981" FontSize="11" Margin="0 5 0 0"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource ControlCard}">
                                <StackPanel>
                                    <TextBlock Text="快捷操作" FontSize="14" FontWeight="Bold" Foreground="#12142D" Margin="0 0 15 0"/>
                                    <Button Content="开始打印批次" Background="#10B981" Foreground="White" Padding="10" Margin="0 0 0 10" BorderThickness="0" />
                                    <Button Content="暂停打印" Background="#F59E0B" Foreground="White" Padding="10" Margin="0 0 0 10" BorderThickness="0" />
                                    <Button Content="紧急停止" Background="#EF4444" Foreground="White" Padding="10" Margin="0 0 0 10" BorderThickness="0" />
                                    <Button Content="停机调试参数" Background="#635BFF" Foreground="White" Padding="10" BorderThickness="0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- 2. 运动控制标签页 -->
            <TabItem Style="{StaticResource TabItemStyle}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🎯" Width="30"/>
                        <TextBlock Text="运动控制"/>
                    </StackPanel>
                </TabItem.Header>
                <!-- 运动控制内容（可根据需求填充） -->
                <Border Background="White" CornerRadius="12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="运动控制模块" FontSize="20" FontWeight="Bold" Foreground="#12142D" Margin="0 0 0 20"/>
                        <TextBlock Text="Z轴定位控制、伺服驱动控制等功能待实现..." Foreground="#666" FontSize="14"/>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- 3. 打印控制标签页 -->
            <TabItem Style="{StaticResource TabItemStyle}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🖨️" Width="30"/>
                        <TextBlock Text="打印控制"/>
                    </StackPanel>
                </TabItem.Header>
                <!-- 打印控制内容（可根据需求填充） -->
                <Border Background="White" CornerRadius="12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="打印控制模块" FontSize="20" FontWeight="Bold" Foreground="#12142D" Margin="0 0 0 20"/>
                        <TextBlock Text="激光功率调节、打印批次控制等功能待实现..." Foreground="#666" FontSize="14"/>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- 4. 平台与工艺标签页 -->
            <TabItem Style="{StaticResource TabItemStyle}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔧" Width="30"/>
                        <TextBlock Text="平台与工艺"/>
                    </StackPanel>
                </TabItem.Header>
                <!-- 平台与工艺内容（可根据需求填充） -->
                <Border Background="White" CornerRadius="12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="平台与工艺模块" FontSize="20" FontWeight="Bold" Foreground="#12142D" Margin="0 0 0 20"/>
                        <TextBlock Text="吸附平台参数、工艺参数配置等功能待实现..." Foreground="#666" FontSize="14"/>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- 5. 质检与监控标签页 -->
            <TabItem Style="{StaticResource TabItemStyle}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✅" Width="30"/>
                        <TextBlock Text="质检与监控"/>
                    </StackPanel>
                </TabItem.Header>
                <!-- 质检与监控内容 - 直接用 UserControl -->
                <local:VisionInspectionPage HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
            </TabItem>

            <!-- 6. 参数配置标签页 -->
            <TabItem Style="{StaticResource TabItemStyle}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚙️" Width="30"/>
                        <TextBlock Text="参数配置"/>
                    </StackPanel>
                </TabItem.Header>
                <!-- 参数配置内容 - 使用Frame导航到ParameterConfigPage -->
                <Frame x:Name="ConfigFrame" NavigationUIVisibility="Hidden"/>
            </TabItem>

            <!-- 7. 退出系统标签项（按钮功能） -->
            <TabItem Style="{StaticResource TabItemStyle}" MouseLeftButtonDown="BtnExit_MouseLeftButtonDown">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🚪" Width="30"/>
                        <TextBlock Text="退出系统"/>
                    </StackPanel>
                </TabItem.Header>
                <Border Background="White" CornerRadius="12" Padding="20">
                    <TextBlock Text="点击左侧退出系统按钮可退出程序" Foreground="#666" FontSize="14"/>
                </Border>
            </TabItem>
        </TabControl>

        <!-- 系统标题（悬浮在左上角） -->
        <StackPanel Orientation="Horizontal" Margin="30 20 0 0" Panel.ZIndex="10">
            <TextBlock Text="⚙️" Foreground="#FF9D43" FontSize="24"/>
            <TextBlock Text=" 曲面打印控制" Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>