<UserControl x:Class="WpfApp1.ParameterConfigPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F7FA">

    <UserControl.Resources>
        <!-- 卡片样式 -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0 0 15 15"/>
        </Style>

        <!-- 标签样式 -->
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0 0 0 8"/>
        </Style>

        <!-- 输入框样式 -->
        <Style x:Key="InputTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="12 10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <!-- 保存按钮样式 -->
        <Style x:Key="SaveButton" TargetType="Button">
            <Setter Property="Background" Value="#10B981"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="30 14"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 重置按钮样式 -->
        <Style x:Key="ResetButton" TargetType="Button">
            <Setter Property="Background" Value="#6B7280"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="30 14"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 页面标题 -->
        <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="0 0 0 15">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⚙️" FontSize="24" VerticalAlignment="Center"/>
                    <TextBlock Text=" 参数配置" FontSize="20" FontWeight="Bold" Foreground="#12142D" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" 
                           Foreground="#666" FontSize="13">
                    <Run Text="配置文件: "/>
                    <Run x:Name="ConfigFilePath" Text="config.ini"/>
                </TextBlock>
            </Grid>
        </Border>

        <!-- 主要内容区 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="600" HorizontalAlignment="Left">
                
                <!-- 海康相机配置卡片 -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 20">
                            <TextBlock Text="📷" FontSize="20" VerticalAlignment="Center"/>
                            <TextBlock Text=" 海康相机配置" FontSize="16" FontWeight="Bold" Foreground="#12142D" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- 设备类型 -->
                        <TextBlock Style="{StaticResource LabelText}" Text="设备类型"/>
                        <ComboBox x:Name="DeviceTypeCombo" SelectedIndex="0" Padding="12 10" Margin="0 0 0 15" FontSize="14">
                            <ComboBoxItem Content="海康威视 MV系列"/>
                            <ComboBoxItem Content="海康威视 CA系列"/>
                            <ComboBoxItem Content="海康威视 CH系列"/>
                        </ComboBox>

                        <!-- 连接方式 -->
                        <TextBlock Style="{StaticResource LabelText}" Text="连接方式"/>
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 15">
                            <RadioButton x:Name="RbtSerialNo" Content="设备序列号" IsChecked="True" 
                                         GroupName="ConnectionType" Margin="0 0 20 0" Checked="ConnectionType_Changed"/>
                            <RadioButton x:Name="RbtIp" Content="IP地址" 
                                         GroupName="ConnectionType" Checked="ConnectionType_Changed"/>
                        </StackPanel>

                        <!-- 设备序列号 -->
                        <TextBlock x:Name="LblSerialNo" Style="{StaticResource LabelText}" Text="设备序列号"/>
                        <TextBox x:Name="TxtSerialNo" Style="{StaticResource InputTextBox}" Margin="0 0 0 5"/>
                        <TextBlock Text="请输入海康相机的设备序列号" Foreground="#999" FontSize="11" Margin="0 0 0 15"/>

                        <!-- IP地址（隐藏/显示切换） -->
                        <StackPanel x:Name="IpPanel" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource LabelText}" Text="IP地址"/>
                            <TextBox x:Name="TxtIpAddress" Style="{StaticResource InputTextBox}" Margin="0 0 0 5"/>
                            <TextBlock Text="请输入海康相机的IP地址（如: 192.168.1.64）" Foreground="#999" FontSize="11" Margin="0 0 0 15"/>
                        </StackPanel>

                        <!-- 用户名 -->
                        <TextBlock Style="{StaticResource LabelText}" Text="用户名（可选）"/>
                        <TextBox x:Name="TxtUsername" Style="{StaticResource InputTextBox}" Margin="0 0 0 15"/>

                        <!-- 密码 -->
                        <TextBlock Style="{StaticResource LabelText}" Text="密码（可选）"/>
                        <PasswordBox x:Name="TxtPassword" Padding="12 10" Margin="0 0 0 15"/>
                    </StackPanel>
                </Border>

                <!-- 连接测试卡片 -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="🔍 连接测试" FontSize="16" FontWeight="Bold" Foreground="#12142D" Margin="0 0 0 15"/>
                        <TextBlock Text="保存配置前，建议先测试连接是否正常。" Foreground="#666" Margin="0 0 0 15"/>
                        <Button x:Name="BtnTestConnection" Content="测试连接" Padding="20 12" 
                                Background="#635BFF" Foreground="White" BorderThickness="0" 
                                Cursor="Hand" Click="BtnTestConnection_Click"/>
                        <StackPanel x:Name="TestResultPanel" Visibility="Collapsed" Margin="0 15 0 0">
                            <Border CornerRadius="8" Padding="15">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="TestResultIcon" Text="✓" FontSize="16" Margin="0 0 10 0"/>
                                    <TextBlock x:Name="TestResultText" FontSize="14"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 其他参数卡片 -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="📋 其他参数" FontSize="16" FontWeight="Bold" Foreground="#12142D" Margin="0 0 0 15"/>
                        
                        <TextBlock Style="{StaticResource LabelText}" Text="超时时间（毫秒）"/>
                        <TextBox x:Name="TxtTimeout" Style="{StaticResource InputTextBox}" Text="3000" Margin="0 0 0 15"/>

                        <TextBlock Style="{StaticResource LabelText}" Text="重试次数"/>
                        <TextBox x:Name="TxtRetryCount" Style="{StaticResource InputTextBox}" Text="3" Margin="0 0 0 15"/>

                        <CheckBox x:Name="ChkAutoConnect" Content="启动时自动连接" Margin="0 0 0 10"/>
                        <CheckBox x:Name="ChkSaveLog" Content="保存操作日志" IsChecked="True"/>
                    </StackPanel>
                </Border>

                <!-- 保存/重置按钮 -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="BtnSave" Content="保存配置" Style="{StaticResource SaveButton}" 
                                Click="BtnSave_Click"/>
                        <Button Content="重置" Style="{StaticResource ResetButton}" 
                                Margin="15 0 0 0" Click="BtnReset_Click"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
